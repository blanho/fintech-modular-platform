# ──────────────────────────────────────────────
# FinTech Platform — Environment Configuration
# Copy to .env and customize for your environment
# ──────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=fintech
POSTGRES_USER=fintech
POSTGRES_PASSWORD=fintech_dev_password
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_EMAIL=admin@fintech.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Redis
REDIS_PORT=6379
REDIS_COMMANDER_PORT=8081

# RabbitMQ
RABBITMQ_USER=fintech
RABBITMQ_PASSWORD=fintech_dev_password
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# API
API_PORT=8080
JWT_SECRET=FinTechPlatformSuperSecretKeyThatIsAtLeast32CharactersLong2024!
