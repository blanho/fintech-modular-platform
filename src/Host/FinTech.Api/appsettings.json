{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=fintech;Username=fintech;Password=fintech_dev_password",
    "Redis": "localhost:6379"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Username": "fintech",
    "Password": "fintech_dev_password"
  },
  "Jwt": {
    "Secret": "FinTechPlatformSuperSecretKeyThatIsAtLeast32CharactersLong2024!",
    "Issuer": "fintech-api",
    "Audience": "fintech-client",
    "ExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173", "http://localhost:3000" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning",
        "MassTransit": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Caching": {
    "DefaultExpirationMinutes": 5,
    "BalanceCacheSeconds": 30,
    "UserProfileCacheMinutes": 10,
    "WalletDetailsCacheMinutes": 5
  }
}
